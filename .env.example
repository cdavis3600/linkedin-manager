# ─────────────────────────────────────────────
#  LinkedIn Manager — Environment Variables
# ─────────────────────────────────────────────

# ── LinkedIn App (for POSTING to your personal profile) ──
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# ── LinkedIn Tokens (filled automatically by oauth_setup.py) ──
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_ID=

# ── Source URLs to monitor (comma-separated, no spaces) ──
# Add any mix of company pages and personal profiles you want to watch
SOURCE_LINKEDIN_URLS=https://www.linkedin.com/company/the-famous-group/,https://www.linkedin.com/in/someone-else/

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Discord ───────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPROVAL_CHANNEL_ID=your_discord_channel_id_here

# ── Scheduler ────────────────────────────────
SCHEDULE_HOUR=10
SCHEDULE_MINUTE=0
TIMEZONE=America/New_York

# ── App Settings ─────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/linkedin_manager.db
MEDIA_DIR=data/media
MAX_POSTS_PER_RUN=5
APPROVAL_TIMEOUT_HOURS=12
