# ─────────────────────────────────────────────
#  LinkedIn Manager — Environment Variables
# ─────────────────────────────────────────────

# ── LinkedIn App (for POSTING to your personal profile) ──
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# ── LinkedIn Tokens (filled automatically by oauth_setup.py) ──
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_MEMBER_ID=

# ── Source URLs to monitor ─────────────────────────────────
# Prefix each URL with its post type: tfg | inspiration | industry
#   tfg         → your own company (TFG) posts — CJ reacts with team pride
#   inspiration → people CJ follows — CJ riffs with curiosity
#   industry    → industry news/trends — CJ shares his opinionated take
#
# Format: type:url,type:url,...  (no spaces)
#
SOURCE_LINKEDIN_URLS=tfg:https://www.linkedin.com/company/the-famous-group/,inspiration:https://www.linkedin.com/in/someone-else/,industry:https://www.linkedin.com/company/some-industry-source/

# ── Team Roster (for Discord tagging step) ─────────────────
# Format per entry: Name|Title|LinkedInURL
# Entries are separated by SEMICOLONS (not commas — titles can contain commas).
#   - Title is shown in Discord so you know who to pick
#   - LinkedIn URL is appended to the post when that person is tagged
# Leave empty to skip the tagging step entirely.
#
TEAM_MEMBERS=Jane Smith|Creative Director|https://www.linkedin.com/in/jane-smith/;John Doe|Producer, Creative Production|https://www.linkedin.com/in/john-doe/

# ── OpenAI ───────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ── Discord ───────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_APPROVAL_CHANNEL_ID=your_discord_channel_id_here

# ── Scheduler ────────────────────────────────
SCHEDULE_HOUR=10
SCHEDULE_MINUTE=0
TIMEZONE=America/New_York

# ── App Settings ─────────────────────────────
LOG_LEVEL=INFO
DB_PATH=data/linkedin_manager.db
MEDIA_DIR=data/media
MAX_POSTS_PER_RUN=5
APPROVAL_TIMEOUT_HOURS=12
